apiVersion: v1
kind: Secret
metadata:
  name: openai-secret
  namespace: meta-test
type: Opaque
stringData:
  OPENAI_API_KEY: "sk-proj-YOUR_KEY_HERE"
---
apiVersion: v1
kind: Secret
metadata:
  name: aws-secret
  namespace: meta-test
type: Opaque
stringData:
  AWS_ACCESS_KEY_ID: "YOUR_ACCESS_KEY"
  AWS_SECRET_ACCESS_KEY: "YOUR_SECRET_KEY"
